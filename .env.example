# PostgreSQL async DSN — must start with postgresql+asyncpg://
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/revenue_os

# Redis connection URL used by the app directly
# Format: redis://:password@host:port/db_index
REDIS_URL=redis://localhost:6379/0

# Celery broker — typically same Redis instance, different db index
# Format: redis://:password@host:port/db_index
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend — stores task state and return values
# Format: redis://:password@host:port/db_index
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Random secret key used for signing tokens; generate with: openssl rand -hex 32
SECRET_KEY=changeme

# Enable verbose error responses and auto-reload; set to False in production
DEBUG=True

# Deployment environment; one of: development | staging | production
APP_ENV=development
