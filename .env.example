# PostgreSQL async connection string (must start with postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/revenue_os

# Redis connection string used by Celery broker and result backend
REDIS_URL=redis://localhost:6379/0

# Celery broker URL (usually same as REDIS_URL)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend URL
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Secret key used for signing tokens / encryption — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret

# Debug mode — set to False in production
DEBUG=True

# Application environment — one of: development | staging | production
APP_ENV=development
